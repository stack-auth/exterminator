# LLM API key -- at least one is required.
# BROWSER_USE_API_KEY is checked first and runs the native bu-latest model.
# Fallback: ANTHROPIC_API_KEY or OPENAI_API_KEY for any LangChain-compatible model.
BROWSER_USE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# URL of the locally running app to test against
APP_URL=http://localhost:3001

# Absolute path to the client's source code (used by the fix agent)
SOURCE_DIR=/path/to/clients/source/code
